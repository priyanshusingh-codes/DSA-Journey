// Data Types in C++
#include <iostream> 
using namespace std;
int main ()
{
    // Integer data type
    // Size: Typically 4 bytes (32 bits) on most systems
    int myNum = 5;               // Integer (whole number)
    cout << "Integer: " << myNum << endl;

    // Floating-point data type
    // Size: Typically 4 bytes (32 bits) on most systems

    float myFloatNum = 5.99;     // Floating point number (with decimals)
    // Note: The actual precision of a float is about 7 decimal digits
    cout << "Float: " << myFloatNum << endl;

    // Double data type
    // Size: Typically 8 bytes (64 bits) on most systems
    double myDoubleNum = 9.98;   // Double-precision floating point number
    cout << "Double: " << myDoubleNum << endl;

    // Character data type
    // Size: Typically 1 byte (8 bits) on most systems
    char myLetter = 'A';         // Character (single letter or symbol)
    cout << "Character: " << myLetter << endl;

    // Boolean data type
    // Size: Typically 1 byte (8 bits) on most systems
    bool myBoolean = true;       // Boolean (true or false)
    cout << "Boolean: " << myBoolean << endl;

    return 0;
}